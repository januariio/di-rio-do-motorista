# Supabase - encontre em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
#
# URL do projeto (formato: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
#
# Anon Key (JWT longo que começa com "eyJ...")
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Maps - autocomplete de cidades, distância e postos de combustível
# Obtenha em: https://console.cloud.google.com/apis/credentials
# APIs necessárias: Routes API, Places API (New)
VITE_GOOGLE_MAPS_API_KEY=sua-api-key-aqui
